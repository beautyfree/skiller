{
  "name": "skiller",
  "version": "0.1.0",
  "description": "A desktop app for managing AI agent skills across Claude Code, Cursor, Copilot, Gemini CLI, and more",
  "license": "MIT",
  "author": "Skiller Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/beautyfree/skiller-skills-desktop-manager"
  },
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev:electron": "electron-vite dev",
    "build:electron": "electron-vite build",
    "start:electron": "electron-vite preview",
    "dev": "bun run build:native-effects && electrobun dev --watch",
    "start": "bun run build && electrobun dev",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5180",
    "dev:debug": "AGENTSKILLS_DEVTOOLS=1 bun run dev:hmr",
    "dev:vite": "vite",
    "build:native-effects": "bun scripts/build-native.ts",
    "build": "bun run build:native-effects && tsc && vite build",
    "build:mac": "bun run build && electrobun build --env=stable",
    "build:win": "bun run build && electrobun build --env=stable",
    "build:linux": "bun run build && electrobun build --env=stable",
    "repack:mac-dmg": "bash scripts/repack-dmg.sh stable",
    "dist:mac": "bun run build:mac && bun run repack:mac-dmg && echo '\\n✓ Distributable artifacts are in ./artifacts/\\n  Send stable-macos-arm64-Skiller.dmg to any Mac user — signed, notarized, and styled with a drag-to-Applications layout.'",
    "dist:win": "bun run build:win && echo '\\n✓ Distributable artifacts are in ./artifacts/\\n  Ship stable-win-x64-Skiller* files to Windows users.'",
    "dist:linux": "bun run build:linux && echo '\\n✓ Distributable artifacts are in ./artifacts/\\n  Ship stable-linux-x64-Skiller* files to Linux users.'",
    "preview": "vite preview",
    "electrobun": "electrobun"
  },
  "dependencies": {
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@base-ui/react": "^1.3.0",
    "@iarna/toml": "^2.2.5",
    "@lobehub/icons": "^5.0.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/bun": "^1.3.12",
    "cheerio": "^1.2.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electrobun": "^1.16.0",
    "handlebars": "^4.7.9",
    "i18next": "^25.8.19",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.0.8",
    "simple-git": "^3.35.2",
    "siphash": "^1.2.0",
    "tailwind-merge": "^3.5.0",
    "toml": "^4.1.1",
    "tw-animate-css": "^1.4.0",
    "which": "^6.0.1",
    "yaml": "^2.8.3",
    "zod": "^3.24.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@trpc/react-query": "^11.0.0",
    "@types/handlebars": "^4.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.183.1",
    "@types/which": "^3.0.4",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}