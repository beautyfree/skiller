{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node", "electron"],
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "outDir": "./out/tsc-node",
    "declarationDir": "./out/tsc-node"
  },
  "include": [
    "vite.config.ts",
    "electron.vite.config.ts",
    "src/electron-main/**/*",
    "src/preload/**/*"
  ]
}
